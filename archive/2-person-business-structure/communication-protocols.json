{
  "communication_protocols": {
    "version": "1.0.0",
    "message_formats": {
      "standard_message": {
        "message_id": "string",
        "timestamp": "ISO8601",
        "sender_agent": "string",
        "recipient_agent": "string",
        "message_type": "request|response|notification|escalation",
        "priority": "low|medium|high|critical",
        "content": {
          "subject": "string",
          "body": "string",
          "context": "object",
          "attachments": "array",
          "action_required": "boolean",
          "deadline": "ISO8601"
        },
        "metadata": {
          "conversation_id": "string",
          "correlation_id": "string",
          "human_visibility": "full|summary|none"
        }
      }
    },
    "communication_patterns": {
      "request_response": {
        "description": "Specific information or action requests",
        "flow": "Agent A → Agent B → Agent A",
        "timeout": "24_hours",
        "escalation": "if_no_response_within_timeout"
      },
      "broadcast": {
        "description": "Company-wide announcements or updates",
        "flow": "Sender → All Relevant Agents",
        "response": "optional_acknowledgment",
        "filtering": "based_on_relevance_and_permissions"
      },
      "escalation": {
        "description": "Issues requiring human intervention",
        "flow": "Agent → Department Agent → Executive Agent → Human",
        "priority": "high_or_critical",
        "response_time": "2_hours"
      },
      "collaboration": {
        "description": "Multi-agent project coordination",
        "flow": "Bidirectional between multiple agents",
        "duration": "project_lifecycle",
        "coordination": "Project Management Agent oversight"
      }
    },
    "escalation_routing": {
      "strategic_issues": {
        "path": "Department Agent → Executive Agent → CEO",
        "timeout": "4_hours",
        "priority": "high"
      },
      "operational_issues": {
        "path": "Department Agent → COO",
        "timeout": "2_hours",
        "priority": "medium"
      },
      "technical_issues": {
        "path": "Department Agent → CTO Agent → CEO (if needed)",
        "timeout": "2_hours",
        "priority": "medium"
      },
      "financial_issues": {
        "path": "Department Agent → CFO Agent → CEO",
        "timeout": "1_hour",
        "priority": "high"
      },
      "cross_functional_issues": {
        "path": "All Relevant Agents → CEO + COO",
        "timeout": "4_hours",
        "priority": "high"
      }
    },
    "context_sharing_rules": {
      "between_executives": {
        "level": "full",
        "includes": ["strategic_context", "decision_rationale", "resource_implications"]
      },
      "between_departments": {
        "level": "relevant_only",
        "includes": ["operational_impact", "resource_requirements", "timeline_implications"]
      },
      "sub_agent_to_parent": {
        "level": "comprehensive",
        "includes": ["detailed_analysis", "recommendations", "implementation_plan"]
      },
      "to_humans": {
        "level": "summarized_with_details_available",
        "includes": ["executive_summary", "key_recommendations", "action_items"]
      }
    },
    "notification_settings": {
      "CEO": {
        "immediate": [
          "critical_escalations",
          "strategic_decisions_required",
          "major_financial_implications",
          "partnership_opportunities",
          "security_incidents"
        ],
        "daily_summary": [
          "executive_agent_performance",
          "strategic_kpi_progress",
          "market_intelligence",
          "competitive_analysis"
        ],
        "weekly_review": [
          "comprehensive_performance_analysis",
          "strategic_alignment_assessment",
          "resource_allocation_review",
          "risk_assessment_update"
        ]
      },
      "COO": {
        "immediate": [
          "operational_escalations",
          "resource_conflicts",
          "process_issues",
          "department_performance_issues"
        ],
        "daily_summary": [
          "department_agent_performance",
          "operational_efficiency_metrics",
          "resource_utilization",
          "process_optimization_opportunities"
        ],
        "weekly_review": [
          "operational_performance_analysis",
          "cross_department_coordination",
          "process_improvement_recommendations",
          "resource_allocation_optimization"
        ]
      }
    },
    "conflict_resolution": {
      "agent_disagreements": {
        "level_1": {
          "description": "Minor differences in approach or priority",
          "process": "Direct communication between agents",
          "timeline": "24_hours",
          "escalation": "if_no_resolution"
        },
        "level_2": {
          "description": "Significant differences between department agents",
          "process": "Department agent coordination",
          "timeline": "48_hours",
          "escalation": "if_no_resolution"
        },
        "level_3": {
          "description": "Major conflicts between executive agents",
          "process": "Executive agent coordination",
          "timeline": "72_hours",
          "escalation": "if_no_resolution"
        },
        "level_4": {
          "description": "Irreconcilable differences or strategic conflicts",
          "process": "Human decision-making",
          "timeline": "as_needed",
          "documentation": "complete_rationale_and_decision_record"
        }
      }
    },
    "performance_monitoring": {
      "communication_metrics": [
        "message_volume",
        "response_times",
        "escalation_frequency",
        "resolution_success_rate",
        "human_override_frequency"
      ],
      "quality_metrics": [
        "message_clarity",
        "decision_accuracy",
        "recommendation_success_rate",
        "collaboration_effectiveness"
      ],
      "efficiency_metrics": [
        "task_completion_time",
        "resource_utilization",
        "automation_success_rate",
        "process_optimization_impact"
      ]
    }
  }
}