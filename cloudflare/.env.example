# NeuroLift Solutions - Cloudflare Environment Configuration
# ===========================================================
#
# Copy this file to .env and fill in your actual values
# Usage: cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# The .env file contains sensitive credentials.

# Cloudflare API Credentials
# ---------------------------
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.Zone, Zone.DNS, Workers Scripts
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Get your account ID from: https://dash.cloudflare.com/
# Found in the URL when viewing your account or on any zone page
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here

# Zone Configuration
# ------------------
# Your domain zone ID (found on the domain overview page)
CLOUDFLARE_ZONE_ID=your-zone-id-here

# WordPress Configuration
# -----------------------
# Primary domain
WORDPRESS_DOMAIN=neuroliftsolutions.com

# Origin server IP (your hosting provider's IP)
ORIGIN_IP=your-hosting-ip-here

# WordPress admin email
WORDPRESS_EMAIL=neuro.edge24@gmail.com

# Workers Configuration
# ---------------------
# Worker names (customize if needed)
WORKER_MAIN=neurolift-main-worker
WORKER_WORDPRESS=neurolift-wordpress-optimizer
WORKER_SECURITY=neurolift-security-worker

# Pages Configuration
# -------------------
# Pages project name
PAGES_PROJECT=neurolift-solutions

# Production branch
PAGES_PRODUCTION_BRANCH=main

# Environment
# -----------
# Options: development, staging, production
NEUROLIFT_ENV=production

# Version
NEUROLIFT_VERSION=1.0.0

# Optional: Analytics
# -------------------
# Enable web analytics
ANALYTICS_ENABLED=true

# Optional: KV Namespace IDs
# --------------------------
# Create KV namespaces at: https://dash.cloudflare.com/kv
# KV_CACHE_ID=your-cache-kv-namespace-id
# KV_SESSIONS_ID=your-sessions-kv-namespace-id

# Optional: R2 Bucket Names
# -------------------------
# Create R2 buckets at: https://dash.cloudflare.com/r2
# R2_ASSETS_BUCKET=neurolift-assets
# R2_BACKUPS_BUCKET=neurolift-backups

# Optional: D1 Database ID
# ------------------------
# Create D1 database at: https://dash.cloudflare.com/d1
# D1_DATABASE_ID=your-d1-database-id

# Optional: Email Configuration
# -----------------------------
# For email routing/sending
# EMAIL_FROM=noreply@neuroliftsolutions.com
# EMAIL_ADMIN=neuro.edge24@gmail.com

# Optional: Security Settings
# ---------------------------
# Rate limiting settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security level (options: off, essentially_off, low, medium, high, under_attack)
SECURITY_LEVEL=medium

# Optional: Cache Settings
# ------------------------
# Browser cache TTL (in seconds)
BROWSER_CACHE_TTL=14400

# Edge cache TTL for static assets (in seconds)
EDGE_CACHE_TTL=86400

# Optional: SSL/TLS Settings
# --------------------------
# SSL mode (options: off, flexible, full, strict)
SSL_MODE=flexible

# Optional: TOI-OTOI Framework Integration
# ----------------------------------------
# For future AI framework integration
# TOI_OTOI_API_ENDPOINT=https://api.neuroliftsolutions.com
# TOI_OTOI_API_KEY=your-toi-otoi-api-key

# Optional: Third-party Integrations
# ----------------------------------
# Google Analytics
# GA_TRACKING_ID=UA-XXXXX-Y

# Facebook Pixel
# FB_PIXEL_ID=your-fb-pixel-id

# Optional: Development Settings
# ------------------------------
# Enable debug mode
# DEBUG=false

# Log level (options: error, warn, info, debug)
# LOG_LEVEL=info

# Notes
# -----
# 1. After setting these values, load them with:
#    source .env  (in bash)
#    or use a .env loader in your application
#
# 2. For production, consider using Cloudflare's environment variables
#    in the dashboard instead of .env files
#
# 3. Keep your .env file secure and never share API tokens
#
# 4. Test your configuration with:
#    ./cloudflare/utils/deploy.sh --status
